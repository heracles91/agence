# Copier ce fichier en server/.env et remplir les valeurs
# Générer JWT_SECRET avec : openssl rand -hex 32

DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/agence
JWT_SECRET=remplacer_par_un_secret_aleatoire_dau_moins_32_caracteres
JWT_EXPIRES_IN=7d
PORT=3001
NODE_ENV=development
ANTHROPIC_API_KEY=sk-ant-...
CORS_ORIGIN=http://localhost:5173
UPLOAD_DIR=uploads

# Connexion via socket Unix (PostgreSQL local sans mot de passe) :
# DATABASE_URL=postgresql://USER@localhost/agence?host=/var/run/postgresql
